# Docker Compose deployment variables (copy to .env before docker compose up)

# Database
DB_NAME=nckh
DB_USER=postgres
DB_PASSWORD=ChangeMe_DbPassword_AtLeast16Chars

# Backend security
JWT_SECRET=ChangeMe_JwtSecret_UseLongRandomString_32Plus
BCRYPT_SALT_ROUNDS=10
TRUST_PROXY=1

# CORS origins for browser requests to backend
# Use your real public domain/IP, comma separated.
# Example: CORS_ORIGIN=http://34.120.10.20,https://example.com
CORS_ORIGIN=http://localhost,http://127.0.0.1

# Default admin seeded by seed:admin
ADMIN_EMAIL=admin@nckh.local
ADMIN_PASSWORD=ChangeMe_AdminPassword_Strong
ADMIN_FULL_NAME=Default Admin
ADMIN_RESET_PASSWORD=false

# Nginx host port
NGINX_HTTP_PORT=80

# Optional DB wait tuning
DB_WAIT_TIMEOUT_MS=120000
DB_WAIT_INTERVAL_MS=2000
