PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nckh
JWT_SECRET=ChangeMe_JwtSecret_UseLongRandomString_32Plus
BCRYPT_SALT_ROUNDS=10
TRUST_PROXY=1
CORS_ORIGIN=http://localhost:5173,http://localhost,http://127.0.0.1,http://localhost:80
UPLOAD_ROOT=uploads
ADMIN_EMAIL=admin@nckh.local
ADMIN_PASSWORD=ChangeMe_AdminPassword_Strong
ADMIN_FULL_NAME=Default Admin
ADMIN_RESET_PASSWORD=false
DB_WAIT_TIMEOUT_MS=120000
DB_WAIT_INTERVAL_MS=2000

# ========== SSL / HTTPS ==========
# Mặc định: HTTP-only. Sau khi chạy scripts/setup-ssl.sh, script sẽ tự cập nhật.
# HTTP mode (default):
NGINX_CONF=./infra/nginx/default.conf
# SSL mode (sau khi chạy setup-ssl.sh):
# NGINX_CONF=./infra/nginx/ssl.conf
NGINX_DOMAIN=yourdomain.com
NGINX_HTTPS_PORT=443
